# Copie este arquivo para .env e preencha com suas credenciais
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.eexyhqvpgbdkzjtfraaw.supabase.co:5432/postgres

# Chave usada pelo painel (header X-API-Key). Gere uma string longa e aleatória (>= 32 chars).
# Deve ser a MESMA configurada no frontend (.env.local).
API_KEY=chave_longa_aleatoria_min_32_chars

# Origens liberadas no CORS (separadas por vírgula). Em produção, use a URL real do front.
CORS_ORIGINS=http://localhost:3000
