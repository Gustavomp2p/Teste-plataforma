# Copie para .env.local e ajuste conforme o ambiente.
# Estas variáveis são usadas apenas no servidor Next.js, nunca expostas ao navegador.

# URL do backend FastAPI.
API_URL=http://localhost:8000

# Chave do painel (header X-API-Key). Deve ser a MESMA configurada no backend (.env).
API_KEY=chave_longa_aleatoria_min_32_chars
